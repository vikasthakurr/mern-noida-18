<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>E-commerce Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7fa;
            margin: 0;
            display: flex;
        }

        .sidebar {
            width: 250px;
            background-color: #2c3e50;
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 20px;
            height: 100vh;
        }

        .sidebar h2 {
            font-size: 1.5rem;
            margin-bottom: 30px;
        }

        .sidebar ul {
            list-style: none;
            padding: 0;
            width: 100%;
        }

        .sidebar ul li {
            padding: 15px 20px;
            cursor: pointer;
            transition: background-color 0.3s;
        }

        .sidebar ul li:hover, .sidebar ul li.active {
            background-color: #34495e;
        }

        .sidebar ul li i {
            margin-right: 10px;
        }

        .main-content {
            flex-grow: 1;
            padding: 40px;
            overflow: auto;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        header h1 {
            font-size: 2rem;
            color: #2c3e50;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background-color: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            display: flex;
            align-items: center;
        }

        .card .icon {
            font-size: 2.5rem;
            margin-right: 20px;
        }
        
        .card .info h3 {
            margin: 0;
            font-size: 1.5rem;
        }

        .card .info p {
            margin: 0;
            color: #7f8c8d;
        }
        
        .card.sales .icon { color: #27ae60; }
        .card.users .icon { color: #2980b9; }
        .card.orders .icon { color: #f39c12; }
        .card.pending .icon { color: #c0392b; }

        .charts-and-tables {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 30px;
        }

        .chart, .table-container {
            background-color: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .chart h2, .table-container h2 {
            margin-top: 0;
            color: #2c3e50;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ecf0f1;
        }

        th {
            background-color: #f4f7fa;
            color: #7f8c8d;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <h2>Dashboard</h2>
        <ul>
            <li class="active"><i class="fas fa-home"></i> Overview</li>
            <li><i class="fas fa-box-open"></i> Products</li>
            <li><i class="fas fa-shopping-cart"></i> Orders</li>
            <li><i class="fas fa-users"></i> Customers</li>
            <li><i class="fas fa-chart-line"></i> Analytics</li>
            <li><i class="fas fa-cog"></i> Settings</li>
        </ul>
    </div>

    <div class="main-content">
        <header>
            <h1>Welcome to E-com Dashboard</h1>
        </header>

        <div class="cards">
            <div class="card sales">
                <div class="icon"><i class="fas fa-dollar-sign"></i></div>
                <div class="info">
                    <h3>$24,890</h3>
                    <p>Total Sales</p>
                </div>
            </div>
            <div class="card users">
                <div class="icon"><i class="fas fa-users"></i></div>
                <div class="info">
                    <h3>1,254</h3>
                    <p>Total Users</p>
                </div>
            </div>
            <div class="card orders">
                <div class="icon"><i class="fas fa-shopping-bag"></i></div>
                <div class="info">
                    <h3>650</h3>
                    <p>Total Orders</p>
                </div>
            </div>
             <div class="card pending">
                <div class="icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="info">
                    <h3>15</h3>
                    <p>Pending Orders</p>
                </div>
            </div>
        </div>

        <div class="charts-and-tables">
            <div class="table-container">
                <h2>Recent Orders</h2>
                <table>
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>#12345</td>
                            <td>John Doe</td>
                            <td>$150.00</td>
                            <td>Shipped</td>
                        </tr>
                        <tr>
                            <td>#12346</td>
                            <td>Jane Smith</td>
                            <td>$200.50</td>
                            <td>Shipped</td>
                        </tr>
                        <tr>
                            <td>#12347</td>
                            <td>Peter Jones</td>
                            <td>$75.25</td>
                            <td>Processing</td>
                        </tr>
                         <tr>
                            <td>#12348</td>
                            <td>Mary Jane</td>
                            <td>$500.00</td>
                            <td>Shipped</td>
                        </tr>
                         <tr>
                            <td>#12349</td>
                            <td>Chris Lee</td>
                            <td>$95.50</td>
                            <td>Delivered</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <div class="chart">
                <h2>Sales Analytics</h2>
                 <!-- Chart would be rendered here by a JS library -->
                <p style="text-align: center; padding: 40px 0; color: #7f8c8d;">Chart placeholder</p>
            </div>
        </div>
    </div>

</body>
</html>
